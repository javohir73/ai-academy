# AI Academy — environment variables
# -------------------------------------------------------------------
# Copy this file to `.env` (or `.env.local`) and fill in your values.
# `.env*` is gitignored — NEVER commit real keys.
#
# Cloud progress sync is OPTIONAL. With these UNSET, the app runs in
# local-only mode (progress saved in the browser, no accounts) with no
# errors. Set them to enable Supabase auth + cloud sync.
#
# Vite only exposes vars prefixed with VITE_ to the browser. Only put
# PUBLIC values here. The Supabase ANON key is safe to expose (Row Level
# Security protects the data). NEVER put the service_role key in the app.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Your Supabase ANON / public key (Project Settings → API → "anon public").
# Do NOT use the service_role / secret key here.
VITE_SUPABASE_ANON_KEY=
